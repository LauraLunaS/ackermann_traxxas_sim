<?xml version="1.0"?>
<!--
  ============================================================
  MODELO SDF — Traxxas Slash 4x4 VXL Ultimate (68277-4) + RPLidar C1
  
  PARÂMETROS DO DATASHEET OFICIAL (traxxas.com):
    Length:        568mm  = 0.568m
    Width (track): 296mm  = 0.296m  (front e rear track iguais)
    Height:        193mm  = 0.193m
    Wheelbase:     324mm  = 0.324m
    Tire diameter: 109.5mm → raio = 0.05475m
    Weight stock:  2.28kg
    Ground clearance: 47mm = 0.047m

  PARÂMETROS PENDENTES — medir fisicamente:
    [MEDIR_1] Altura do LiDAR (z): medir com régua -> 22
    [MEDIR_2] Ângulo máximo de esterço: medir com transferidor -> 
    [MEDIR_3] Massa total com eletrônicos: pesar o rover completo
    [MEDIR_4] Coeficiente de atrito: testar empiricamente
    

  Lidar no X: 54/2 + 1.5
  Lidar no Y: 24 total e o lidar no 14

  CORREÇÕES v2 (datasheet oficial):
    track_width:   0.255m  →  0.296m  (datasheet: 296mm)
    wheel_radius:  0.054m  →  0.05475m (datasheet: 109.5mm diâmetro)
    height:        0.158m  →  0.193m  (datasheet: 193mm)
    wheel_separation (joint): 0.1275m → 0.148m (296/2)
    kingpin_width: 0.212m  →  0.253m  (296 - 43mm de largura de roda)
  ============================================================
-->
<sdf version="1.8">
  <model name="traxxas">
    <self_collide>false</self_collide>
    <static>false</static>

    <link name="base_link">
      <gz_frame_id>traxxas/base_link</gz_frame_id>

      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <!-- [MEDIR_3] Massa total com eletrônicos -->
        <!-- stock 2.28kg + Raspberry ~0.1kg + LiDAR ~0.17kg + controladora ~0.1kg + bateria ~0.3kg = ~3.0kg -->
        <mass>3.0</mass>
        <!-- Inércia caixa 0.568 x 0.296 x 0.193, m=3.0kg -->
        <!-- Ixx=(1/12)*3.0*(0.193²+0.296²) = 0.0310 -->
        <!-- Iyy=(1/12)*3.0*(0.568²+0.193²) = 0.0903 -->
        <!-- Izz=(1/12)*3.0*(0.568²+0.296²) = 0.1027 -->
        <inertia>
          <ixx>0.0310</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0903</iyy>
          <iyz>0</iyz>
          <izz>0.1027</izz>
        </inertia>
      </inertial>

      <!-- Colisão baseada nas dimensões reais -->
      <collision name="traxxas/BaseCollision">
        <!-- z = ground_clearance + height/2 = 0.047 + 0.0965 = 0.1435 -->
        <pose>0 0 0.1435 0 0 0</pose>
        <geometry>
          <box>
            <size>0.568 0.296 0.193</size>
          </box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <!-- [MEDIR_4] -->
              <mu>0.5</mu>
              <mu2>0.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <!-- ===== VISUAIS ===== -->

      <!-- Plataforma inferior do chassi -->
      <visual name="traxxas/ChassisVisual">
        <pose>0 0 0.055 0 0 0</pose>
        <geometry>
          <box><size>0.520 0.310 0.030</size></box>
        </geometry>
        <material>
          <ambient>0.08 0.08 0.08 1</ambient>
          <diffuse>0.08 0.08 0.08 1</diffuse>
        </material>
      </visual>

      <!-- Corpo central -->
      <visual name="traxxas/CabVisual">
        <pose>0.02 0 0.130 0 0 0</pose>
        <geometry>
          <box><size>0.200 0.300 0.090</size></box>
        </geometry>
        <material>
          <ambient>0.1 0.6 0.1 1</ambient>
          <diffuse>0.1 0.6 0.1 1</diffuse>
        </material>
      </visual>

      <!-- Capô — parte alta -->
      <visual name="traxxas/HoodTopVisual">
        <pose>0.190 0 0.115 0 0.30 0</pose>
        <geometry>
          <box><size>0.180 0.295 0.030</size></box>
        </geometry>
        <material>
          <ambient>0.1 0.6 0.1 1</ambient>
          <diffuse>0.1 0.6 0.1 1</diffuse>
        </material>
      </visual>

      <!-- Capô — parte baixa inclinada -->
      <visual name="traxxas/HoodLowVisual">
        <pose>0.270 0 0.080 0 0.55 0</pose>
        <geometry>
          <box><size>0.120 0.295 0.025</size></box>
        </geometry>
        <material>
          <ambient>0.1 0.6 0.1 1</ambient>
          <diffuse>0.1 0.6 0.1 1</diffuse>
        </material>
      </visual>

      <!-- Para-choque frontal -->
      <visual name="traxxas/FrontBumperVisual">
        <pose>0.295 0 0.060 0 0 0</pose>
        <geometry>
          <box><size>0.030 0.330 0.045</size></box>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>

      <!-- Nerf bar frontal esquerdo -->
      <visual name="traxxas/NerfFrontLeftVisual">
        <pose>0.200 0.162 0.058 0 0 0</pose>
        <geometry>
          <box><size>0.180 0.012 0.012</size></box>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>

      <!-- Nerf bar frontal direito -->
      <visual name="traxxas/NerfFrontRightVisual">
        <pose>0.200 -0.162 0.058 0 0 0</pose>
        <geometry>
          <box><size>0.180 0.012 0.012</size></box>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>

      <!-- Traseira -->
      <visual name="traxxas/RearVisual">
        <pose>-0.200 0 0.105 0 -0.15 0</pose>
        <geometry>
          <box><size>0.150 0.300 0.085</size></box>
        </geometry>
        <material>
          <ambient>0.1 0.6 0.1 1</ambient>
          <diffuse>0.1 0.6 0.1 1</diffuse>
        </material>
      </visual>

      <!-- Para-choque traseiro -->
      <visual name="traxxas/RearBumperVisual">
        <pose>-0.285 0 0.060 0 0 0</pose>
        <geometry>
          <box><size>0.030 0.330 0.045</size></box>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>

      <!-- Nerf bar traseiro esquerdo -->
      <visual name="traxxas/NerfRearLeftVisual">
        <pose>-0.200 0.162 0.058 0 0 0</pose>
        <geometry>
          <box><size>0.180 0.012 0.012</size></box>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>

      <!-- Nerf bar traseiro direito -->
      <visual name="traxxas/NerfRearRightVisual">
        <pose>-0.200 -0.162 0.058 0 0 0</pose>
        <geometry>
          <box><size>0.180 0.012 0.012</size></box>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>

      <!-- Faixa lateral esquerda -->
      <visual name="traxxas/StripeLeftVisual">
        <pose>0.05 0.152 0.100 0 0 0</pose>
        <geometry>
          <box><size>0.400 0.010 0.065</size></box>
        </geometry>
        <material>
          <ambient>0.0 0.35 0.0 1</ambient>
          <diffuse>0.0 0.35 0.0 1</diffuse>
        </material>
      </visual>

      <!-- Faixa lateral direita -->
      <visual name="traxxas/StripeRightVisual">
        <pose>0.05 -0.152 0.100 0 0 0</pose>
        <geometry>
          <box><size>0.400 0.010 0.065</size></box>
        </geometry>
        <material>
          <ambient>0.0 0.35 0.0 1</ambient>
          <diffuse>0.0 0.35 0.0 1</diffuse>
        </material>
      </visual>

      <!-- Arcos de roda dianteiros -->
      <visual name="traxxas/WheelArchFrontLeftVisual">
        <pose>0.162 0.155 0.065 0 0 0</pose>
        <geometry>
          <box><size>0.145 0.015 0.055</size></box>
        </geometry>
        <material>
          <ambient>0.08 0.08 0.08 1</ambient>
          <diffuse>0.08 0.08 0.08 1</diffuse>
        </material>
      </visual>

      <visual name="traxxas/WheelArchFrontRightVisual">
        <pose>0.162 -0.155 0.065 0 0 0</pose>
        <geometry>
          <box><size>0.145 0.015 0.055</size></box>
        </geometry>
        <material>
          <ambient>0.08 0.08 0.08 1</ambient>
          <diffuse>0.08 0.08 0.08 1</diffuse>
        </material>
      </visual>

      <!-- Arcos de roda traseiros -->
      <visual name="traxxas/WheelArchRearLeftVisual">
        <pose>-0.162 0.155 0.065 0 0 0</pose>
        <geometry>
          <box><size>0.145 0.015 0.055</size></box>
        </geometry>
        <material>
          <ambient>0.08 0.08 0.08 1</ambient>
          <diffuse>0.08 0.08 0.08 1</diffuse>
        </material>
      </visual>

      <visual name="traxxas/WheelArchRearRightVisual">
        <pose>-0.162 -0.155 0.065 0 0 0</pose>
        <geometry>
          <box><size>0.145 0.015 0.055</size></box>
        </geometry>
        <material>
          <ambient>0.08 0.08 0.08 1</ambient>
          <diffuse>0.08 0.08 0.08 1</diffuse>
        </material>
      </visual>

      <!-- Suporte do LiDAR -->
      <visual name="traxxas/LidarMountVisual">
        <pose>0 0 0.200 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.015</radius><length>0.040</length></cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>

      <!-- LiDAR RPLidar C1 -->
      <!-- [MEDIR_1] Ajustar z com altura real medida -->
      <visual name="traxxas/LidarVisual">
        <pose>0 0 0.228 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.038</radius><length>0.040</length></cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>

      <!-- Antena -->
      <visual name="traxxas/AntennaVisual">
        <pose>-0.180 0.100 0.220 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.004</radius><length>0.130</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>

      <!-- ===== SENSORES ===== -->

      <!-- IMU -->
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <topic>imu</topic>
        <imu>
          <enable_orientation>1</enable_orientation>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev><bias_mean>0.00075</bias_mean><bias_stddev>0.005</bias_stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev><bias_mean>0.00075</bias_mean><bias_stddev>0.005</bias_stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev><bias_mean>0.00075</bias_mean><bias_stddev>0.005</bias_stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev><bias_mean>0.05</bias_mean><bias_stddev>0.0075</bias_stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev><bias_mean>0.05</bias_mean><bias_stddev>0.0075</bias_stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev><bias_mean>0.05</bias_mean><bias_stddev>0.0075</bias_stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>

      <!-- RPLidar C1 — 2D, 360°, 10Hz, 0.1–12m -->
      <!-- [MEDIR_1] z=0.228 estimado — medir altura real -->
      <sensor name="rplidar_c1" type="gpu_lidar">
        <pose>0 0 0.228 0 0 0</pose>
        <lidar>
          <scan>
            <horizontal>
              <samples>2400</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>0</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
        <gz_frame_id>traxxas/base_link/rplidar_c1</gz_frame_id>
        <topic>scan</topic>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
      </sensor>

    </link>

    <!-- ===== RODAS DIANTEIRAS ===== -->
    <!-- Traxxas: raio = 109.5mm/2 = 54.75mm, largura estimada ~43mm -->

    <link name="front_left_wheel_link">
      <pose relative_to="front_left_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.000120</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000120</iyy><iyz>0</iyz>
          <izz>0.000225</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <visual name="traxxas/FrontLeftWheelVisual">
        <pose>0 0 0 -1.5707 0 0</pose>
        <geometry>
          <cylinder><radius>0.05475</radius><length>0.043</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="traxxas/FrontLeftWheelCollision">
        <pose>0 0 0 -1.5707 0 0</pose>
        <geometry>
          <cylinder><radius>0.05475</radius><length>0.043</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <!-- [MEDIR_4] -->
              <mu>0.8</mu><mu2>1.2</mu2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name="front_left_wheel_steering_link">
      <pose relative_to="front_left_wheel_steering_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia><ixx>0.000004</ixx><iyy>0.000004</iyy><izz>0.000004</izz></inertia>
      </inertial>
    </link>

    <joint name="front_left_wheel_joint" type="revolute">
      <parent>front_left_wheel_steering_link</parent>
      <child>front_left_wheel_link</child>
      <pose relative_to="front_left_wheel_steering_joint">0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <joint name="front_left_wheel_steering_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_left_wheel_steering_link</child>
      <!-- x = wheelbase/2 = 0.162, y = track/2 = 0.148 -->
      <pose relative_to="base_link">0.162 0.148 0 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <!-- [MEDIR_2] -->
          <lower>-0.5</lower><upper>0.5</upper>
          <velocity>1.0</velocity><effort>30</effort>
        </limit>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <link name="front_right_wheel_link">
      <pose relative_to="front_right_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.000120</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000120</iyy><iyz>0</iyz>
          <izz>0.000225</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <visual name="traxxas/FrontRightWheelVisual">
        <pose>0 0 0 -1.5707 0 0</pose>
        <geometry>
          <cylinder><radius>0.05475</radius><length>0.043</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="traxxas/FrontRightWheelCollision">
        <pose>0 0 0 -1.5707 0 0</pose>
        <geometry>
          <cylinder><radius>0.05475</radius><length>0.043</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>0.8</mu><mu2>1.2</mu2><fdir1>0 0 1</fdir1></ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name="front_right_wheel_steering_link">
      <pose relative_to="front_right_wheel_steering_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia><ixx>0.000004</ixx><iyy>0.000004</iyy><izz>0.000004</izz></inertia>
      </inertial>
    </link>

    <joint name="front_right_wheel_joint" type="revolute">
      <parent>front_right_wheel_steering_link</parent>
      <child>front_right_wheel_link</child>
      <pose relative_to="front_right_wheel_steering_joint">0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <joint name="front_right_wheel_steering_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_right_wheel_steering_link</child>
      <!-- x = wheelbase/2 = 0.162, y = -track/2 = -0.148 -->
      <pose relative_to="base_link">0.162 -0.148 0 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.5</lower><upper>0.5</upper>
          <velocity>1.0</velocity><effort>30</effort>
        </limit>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <!-- ===== RODAS TRASEIRAS ===== -->

    <link name="rear_right_wheel_link">
      <pose relative_to="rear_right_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.000120</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000120</iyy><iyz>0</iyz>
          <izz>0.000225</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <visual name="traxxas/RearRightWheelVisual">
        <pose>0 0 0 -1.5707 0 0</pose>
        <geometry>
          <cylinder><radius>0.05475</radius><length>0.043</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="traxxas/RearRightWheelCollision">
        <pose>0 0 0 -1.5707 0 0</pose>
        <geometry>
          <cylinder><radius>0.05475</radius><length>0.043</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>0.8</mu><mu2>1.2</mu2><fdir1>0 0 1</fdir1></ode>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel_link</child>
      <!-- x = -wheelbase/2 = -0.162, y = -track/2 = -0.148 -->
      <pose relative_to="base_link">-0.162 -0.148 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <link name="rear_left_wheel_link">
      <pose relative_to="rear_left_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.000120</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000120</iyy><iyz>0</iyz>
          <izz>0.000225</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <visual name="traxxas/RearLeftWheelVisual">
        <pose>0 0 0 -1.5707 0 0</pose>
        <geometry>
          <cylinder><radius>0.05475</radius><length>0.043</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="traxxas/RearLeftWheelCollision">
        <pose>0 0 0 -1.5707 0 0</pose>
        <geometry>
          <cylinder><radius>0.05475</radius><length>0.043</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>0.8</mu><mu2>1.2</mu2><fdir1>0 0 1</fdir1></ode>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel_link</child>
      <!-- x = -wheelbase/2 = -0.162, y = track/2 = 0.148 -->
      <pose relative_to="base_link">-0.162 0.148 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <!-- ===== PLUGIN ACKERMANN ===== -->
    <plugin filename="gz-sim-ackermann-steering-system"
            name="gz::sim::systems::AckermannSteering">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <left_steering_joint>front_left_wheel_steering_joint</left_steering_joint>
      <right_steering_joint>front_right_wheel_steering_joint</right_steering_joint>
      <!-- kingpin = track - wheel_width = 0.296 - 0.043 = 0.253 -->
      <kingpin_width>0.253</kingpin_width>
      <!-- [MEDIR_2] -->
      <steering_limit>0.5</steering_limit>
      <wheel_base>0.324</wheel_base>
      <wheel_separation>0.296</wheel_separation>
      <wheel_radius>0.05475</wheel_radius>
      <min_velocity>-1.5</min_velocity>
      <max_velocity>1.5</max_velocity>
      <min_acceleration>-3.0</min_acceleration>
      <max_acceleration>3.0</max_acceleration>
      <topic>/cmd_vel</topic>
    </plugin>

    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>traxxas</robot_base_frame>
      <odom_topic>odom</odom_topic>
      <dimensions>3</dimensions>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
    </plugin>

    <plugin filename="gz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_sensor_pose>true</publish_sensor_pose>
      <publish_model_pose>false</publish_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
    </plugin>

  </model>
</sdf>
